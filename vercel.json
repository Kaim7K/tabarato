{
  "crons": [
    {
      "path": "/api/cron/publicar-agendadas",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/admin(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|src/|@vite/|@react-refresh|node_modules/).*)",
      "destination": "/index.html"
    }
  ]
}
