{
  "manifest_version": 3,
  "name": "Ta Barato - Central de Ofertas",
  "description": "Capture ofertas, gere artes e publique no site, Telegram e WhatsApp somente nas lojas conectadas.",
  "version": "4.5.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "declarativeNetRequest",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.mercadolivre.com.br/*",
    "https://*.mercadolibre.com/*",
    "https://*.shopee.com.br/*",
    "https://*.shopeeusercontent.com/*",
    "https://*.susercontent.com/*",
    "https://affiliate.shopee.com.br/*",
    "https://web.whatsapp.com/*",
    "https://www.tabaratoofertas.shop/*",
    "https://tabaratoofertas.shop/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Abrir Ta Barato",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadolivre.com.br/*",
        "https://*.mercadolibre.com/*"
      ],
      "js": [
        "content/mercado-livre-guard.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://*.mercadolivre.com.br/cupons/pdp*",
        "https://*.mercadolibre.com/cupons/pdp*"
      ],
      "js": [
        "content/coupon-frame.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.mercadolivre.com.br/*",
        "https://*.mercadolibre.com/*"
      ],
      "js": [
        "shared/runtime.js",
        "shared/coupon-code.js",
        "content/shared.js",
        "content/stores/mercado-livre.js",
        "content/stores/generic.js",
        "content/index.js",
        "content/coupons.js"
      ],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "https://*.shopee.com.br/*"
      ],
      "js": [
        "shared/runtime.js",
        "shared/coupon-code.js",
        "content/shared.js",
        "content/stores/shopee.js",
        "content/stores/generic.js",
        "content/index.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.tabaratoofertas.shop/*",
        "https://tabaratoofertas.shop/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "shared/runtime.js",
        "shared/coupon-code.js",
        "content/shared.js",
        "content/stores/generic.js",
        "content/index.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "shared/runtime.js",
        "content/whatsapp.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://affiliate.shopee.com.br/*"
      ],
      "js": [
        "shared/runtime.js",
        "content/shopee-affiliate.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icon-128.png"
      ],
      "matches": [
        "https://*.mercadolivre.com.br/*",
        "https://*.mercadolibre.com/*",
        "https://*.shopee.com.br/*",
        "https://www.tabaratoofertas.shop/*",
        "https://tabaratoofertas.shop/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ]
    }
  ]
}
