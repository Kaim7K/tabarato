{
  "manifest_version": 3,
  "name": "Ta Barato - Central de Ofertas",
  "description": "Capture ofertas, gere artes e publique no site, Telegram e WhatsApp somente nas lojas conectadas.",
  "version": "2.0.0",
  "minimum_chrome_version": "116",
  "icons": {
    "128": "assets/icon.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_title": "Abrir Ta Barato",
    "default_icon": {
      "128": "assets/icon.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.mercadolivre.com.br/*",
        "https://*.mercadolibre.com/*"
      ],
      "js": [
        "shared/runtime.js",
        "content/shared.js",
        "content/stores/mercado-livre.js",
        "content/stores/generic.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.shopee.com.br/*"],
      "js": [
        "shared/runtime.js",
        "content/shared.js",
        "content/stores/shopee.js",
        "content/stores/generic.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://tabaratoofertas.vercel.app/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "shared/runtime.js",
        "content/shared.js",
        "content/stores/generic.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": [
        "shared/runtime.js",
        "content/shared.js",
        "content/stores/generic.js",
        "content/index.js",
        "content/whatsapp.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["assets/icon.png"],
    "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"]
  }]
}
